{
  "pluginAlias": "PipoSpeak",
  "pluginType": "platform",
  "singular": true,
  "footerDisplay": "Playback uses the [homebridge-homepod-radio](https://www.npmjs.com/package/homebridge-homepod-radio) `/play` route automatically when that plugin is installed; otherwise it streams directly with **pyatv** (`atvremote`). The LAN HTTP endpoint is **off by default** — only enable it on a trusted network.",
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Platform Name",
        "type": "string",
        "default": "Pipo Speak",
        "required": true,
        "description": "Shown in the Homebridge log only."
      },
      "buttons": {
        "title": "Phrase Buttons",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "title": "Button Name",
              "type": "string",
              "required": true,
              "placeholder": "Dinner is ready"
            },
            "phrase": {
              "title": "Phrase to Speak",
              "type": "string",
              "required": true,
              "placeholder": "Dinner is ready, come to the kitchen."
            },
            "volumeOverride": {
              "title": "Override volume for this phrase",
              "type": "boolean",
              "default": false
            },
            "volume": {
              "title": "Volume (0-100)",
              "type": "integer",
              "minimum": 0,
              "maximum": 100,
              "placeholder": "75",
              "condition": {
                "functionBody": "return Array.isArray(model.buttons) && model.buttons[arrayIndices[0]] && model.buttons[arrayIndices[0]].volumeOverride === true;"
              }
            }
          }
        }
      },
      "defaultVolume": {
        "title": "Default Volume (0-100)",
        "type": "integer",
        "default": 75,
        "minimum": 0,
        "maximum": 100
      },
      "playback": {
        "title": "Playback Target",
        "type": "string",
        "default": "auto",
        "description": "Auto-detects homebridge-homepod-radio and routes audio through it when installed; otherwise streams directly with pyatv. See the link at the bottom of this page.",
        "oneOf": [
          { "title": "Use HomePod Radio if installed", "enum": ["auto"] },
          { "title": "Stream directly with pyatv", "enum": ["pyatv"] }
        ]
      },
      "atvId": {
        "title": "pyatv Device ID",
        "type": "string",
        "placeholder": "AA:BB:CC:DD:EE:FF",
        "description": "Identifier of the target speaker for pyatv (from `atvremote scan`). Required for the pyatv playback target.",
        "condition": {
          "functionBody": "return model.playback !== 'homepod-radio';"
        }
      },
      "voice": {
        "title": "Voice",
        "type": "string",
        "default": "en_US-lessac-low",
        "description": "Offline Piper voice. The voice you pick is downloaded automatically the first time it speaks. \"Light\" voices use the least memory — best on small boards.",
        "oneOf": [
          { "title": "Lessac - US English (light, default)", "enum": ["en_US-lessac-low"] },
          { "title": "Amy - US English female (light)", "enum": ["en_US-amy-low"] },
          { "title": "Ryan - US English male (light)", "enum": ["en_US-ryan-low"] },
          { "title": "Kathleen - US English female (light)", "enum": ["en_US-kathleen-low"] },
          { "title": "Danny - US English male (light)", "enum": ["en_US-danny-low"] },
          { "title": "Alan - British English male (light)", "enum": ["en_GB-alan-low"] },
          { "title": "Lessac - US English (richer, more memory)", "enum": ["en_US-lessac-medium"] },
          { "title": "Amy - US English female (richer, more memory)", "enum": ["en_US-amy-medium"] }
        ]
      },
      "enableHttp": {
        "title": "Enable LAN HTTP \"speak anything\" endpoint",
        "type": "boolean",
        "default": false,
        "description": "When on, exposes POST /say (and GET /say?text=...) so other devices on your network can speak arbitrary text. No authentication — keep it on a trusted LAN only."
      },
      "httpPort": {
        "title": "HTTP Port",
        "type": "integer",
        "default": 8095,
        "minimum": 1,
        "maximum": 65535,
        "condition": {
          "functionBody": "return model.enableHttp === true;"
        }
      },
      "maxChars": {
        "title": "Max Characters Per Utterance",
        "type": "integer",
        "default": 600,
        "minimum": 1,
        "maximum": 4000
      },
      "minAvailableMb": {
        "title": "Minimum Free RAM (MiB) Before Synthesizing",
        "type": "integer",
        "default": 90,
        "minimum": 0,
        "description": "Pre-flight memory gate. If MemAvailable is below this, the request is refused instead of risking an out-of-memory reboot on small boards. Set 0 to disable."
      },
      "cooldownSeconds": {
        "title": "Cooldown Between Utterances (seconds)",
        "type": "number",
        "default": 4,
        "minimum": 0
      },
      "piperThreads": {
        "title": "Piper Thread Cap",
        "type": "integer",
        "minimum": 1,
        "maximum": 8,
        "placeholder": "(default)",
        "description": "Optional. Fewer threads = lower CPU/memory spike, slower synthesis. Recommended: 1 on a single-core / low-RAM board."
      }
    }
  },
  "layout": [
    {
      "type": "section",
      "title": "Phrase Buttons",
      "expandable": true,
      "expanded": true,
      "items": [
        {
          "key": "buttons",
          "type": "array",
          "notitle": true,
          "items": [
            "buttons[].name",
            "buttons[].phrase",
            "buttons[].volumeOverride",
            "buttons[].volume"
          ]
        }
      ]
    },
    {
      "type": "section",
      "title": "Playback",
      "expandable": true,
      "expanded": false,
      "items": ["playback", "defaultVolume", "atvId", "voice"]
    },
    {
      "type": "section",
      "title": "LAN HTTP Endpoint",
      "expandable": true,
      "expanded": false,
      "items": [
        "enableHttp",
        { "key": "httpPort", "type": "number", "placeholder": "8095" }
      ]
    },
    {
      "type": "section",
      "title": "Advanced / Memory Safety",
      "expandable": true,
      "expanded": false,
      "items": ["maxChars", "minAvailableMb", "cooldownSeconds", "piperThreads"]
    }
  ]
}
